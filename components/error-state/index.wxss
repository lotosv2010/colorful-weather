.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
}

.error-state-compact {
  padding: 24rpx 0 8rpx;
}

.error-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
  line-height: 1.6;
}

.retry-btn {
  margin-top: 24rpx;
  padding: 12rpx 48rpx;
  font-size: 28rpx;
  color: #fff;
  background: var(--theme, #1296db);
  border-radius: 32rpx;
  line-height: 1.5;
}
