<!--components/astronomy/index.wxml-->
<wxs src="../../utils/iconColor.wxs" module="ic" />
<wxs src="../../utils/moonPhase.wxs" module="mp" />
<view class="weather-astronomy">
  <view class="weather-astronomy-header">
    <text class="title">太阳和月亮</text>
    <text class="astro-nav-hint-text">预报和更多 ›</text>
  </view>
  <view class="weather-astronomy-main">
    <!-- 太阳折线图 -->
    <view class="astro-chart-section">
      <canvas type="2d" id="sunCanvas" class="astro-canvas"></canvas>
    </view>
    <!-- 当前太阳高度角 -->
    <view class="solar-angle-row" wx:if="{{solarElevation !== null}}">
      <view class="solar-angle-item">
        <text class="solar-angle-label">高度角</text>
        <text class="solar-angle-val">{{solarElevation}}°</text>
      </view>
      <view class="solar-angle-item">
        <text class="solar-angle-label">方位</text>
        <text class="solar-angle-val">{{solarAzimuthDir}}（{{solarAzimuth}}°）</text>
      </view>
      <view class="solar-angle-item">
        <text class="solar-angle-label">太阳时</text>
        <text class="solar-angle-val">{{solarHour || '--'}}</text>
      </view>
    </view>
    <!-- 月亮折线图 -->
    <view class="astro-chart-section">
      <canvas type="2d" id="moonCanvas" class="astro-canvas"></canvas>
    </view>
    <!-- 月相信息 + 月出月落 -->
    <view class="astro-moon-phase" wx:if="{{moonPhaseIcon}}">
      <text class="moon-rise-set" wx:if="{{moonrise !== '--:--'}}">{{moonrise}} 出 · {{moonset !== '--:--' ? moonset : '--:--'}} 落</text>
      <text class="moon-emoji">{{mp.emoji(moonPhaseIcon)}}</text>
      <text class="phase-name">{{moonPhaseName}}</text>
      <text class="phase-illum">照明 {{moonIllumination}}%</text>
    </view>
  </view>
</view>
