/* components/astronomy/index.wxss */
.weather-astronomy {
  background-color: rgb(34, 37, 48);
  padding: 15px;
  border-radius: 15px;
  margin: 10px 0;
  box-sizing: border-box;
}
.weather-astronomy-header {
  font-size: 0.8rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}
.weather-astronomy-header .title {
  color: rgb(181, 187, 204);
}
.weather-astronomy-main {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.astro-chart-section {
  background-color: rgb(46, 48, 61);
  border-radius: 8px;
  padding: 8px 12px;
  overflow: hidden;
}
.astro-canvas {
  width: 100%;
  height: 118px;
  display: block;
}
/* 太阳高度角信息行 */
.solar-angle-row {
  display: flex;
  background-color: rgb(46, 48, 61);
  border-radius: 8px;
  padding: 10px 12px;
}
.solar-angle-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}
.solar-angle-label {
  font-size: 0.7rem;
  color: rgba(255,255,255,.45);
}
.solar-angle-val {
  font-size: 0.8rem;
  font-weight: 500;
  color: #FF8C00;
}
/* 月相信息栏 */
.astro-moon-phase {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8px;
  padding: 8px 12px;
  background-color: rgb(46, 48, 61);
  border-radius: 8px;
}
.moon-rise-set {
  font-size: 0.75rem;
  color: #6CB4EE;
  margin-right: auto;
}
.moon-phase-icon {
  font-size: 1rem;
}
.moon-emoji {
  font-size: 1rem;
}
.phase-name {
  font-size: 0.75rem;
  color: rgb(181, 187, 204);
}
.phase-illum {
  font-size: 0.75rem;
  color: #6CB4EE;
}
