/* components/astronomy/index.wxss */
.weather-astronomy {
  background-color: rgb(34, 37, 48);
  padding: 15px;
  border-radius: 15px;
  margin: 10px 0;
  box-sizing: border-box;
}
.weather-astronomy-header {
  font-size: 0.8rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}
.weather-astronomy-header .title {
  color: rgb(181, 187, 204);
}
.weather-astronomy-main {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.astro-chart-section {
  background-color: rgb(46, 48, 63);
  border-radius: 8px;
  padding: 8px 12px;
  overflow: hidden;
}
.astro-canvas {
  width: 100%;
  height: 110px;
  display: block;
}
/* 月相信息栏 */
.astro-moon-phase {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8px;
  padding: 8px 12px;
  background-color: rgb(46, 48, 63);
  border-radius: 8px;
}
.moon-phase-icon {
  font-size: 1rem;
}
.phase-name {
  font-size: 0.75rem;
  color: rgb(181, 187, 204);
}
.phase-illum {
  font-size: 0.75rem;
  color: #6CB4EE;
}
