/* components/solar/index.wxss */
.weather-solar {
  background-color: rgb(34, 37, 48);
  padding: 15px;
  border-radius: 15px;
  margin: 10px 0;
  box-sizing: border-box;
}

.weather-solar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14px;
}

.weather-solar-header .title {
  font-size: 0.8rem;
}

.weather-solar-header .subtitle {
  font-size: 0.75rem;
  color: #A6A9AD;
}

/* 当前辐照 */
.solar-current {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 12px;
}

.solar-current-left {
  display: flex;
  align-items: baseline;
  gap: 4px;
  flex-wrap: wrap;
}

.solar-value {
  font-size: 2.2rem;
  font-weight: 300;
  line-height: 1;
}

.solar-unit {
  font-size: 0.8rem;
  color: #A6A9AD;
}

.solar-level {
  font-size: 0.7rem;
  padding: 2px 8px;
  border-radius: 10px;
  margin-left: 4px;
}

.level-0 { background: rgba(166,169,173,0.15); color: #A6A9AD; }
.level-1 { background: rgba(255,213,79,0.15); color: #FFD54F; }
.level-2 { background: rgba(255,152,0,0.2); color: #FF9800; }
.level-3 { background: rgba(244,67,54,0.2); color: #F44336; }

.solar-current-right {
  text-align: right;
}

.peak-label {
  font-size: 0.7rem;
  color: #A6A9AD;
  display: block;
}

.peak-time {
  font-size: 0.85rem;
  color: #FFD54F;
  display: block;
}

.peak-value {
  font-size: 0.85rem;
  display: block;
}

/* 强度进度条 */
.solar-bar-wrap {
  margin-bottom: 14px;
}

.solar-bar-bg {
  height: 6px;
  background: #3D3F4A;
  border-radius: 3px;
  overflow: hidden;
  margin-bottom: 4px;
}

.solar-bar-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 0.4s ease;
}

.level-fill-0 { background: #A6A9AD; }
.level-fill-1 { background: linear-gradient(90deg, #FFD54F, #FFB300); }
.level-fill-2 { background: linear-gradient(90deg, #FF9800, #F57C00); }
.level-fill-3 { background: linear-gradient(90deg, #F44336, #B71C1C); }

.solar-bar-labels {
  display: flex;
  justify-content: space-between;
  font-size: 0.6rem;
  color: #A6A9AD;
}

/* 曲线图 */
.solar-canvas-wrap {
  width: 100%;
  height: 100px;
}

.solar-canvas {
  width: 100%;
  height: 100px;
}
