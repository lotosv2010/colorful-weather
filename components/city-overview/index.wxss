/* 全屏遮罩 */
.city-overview {
  position: fixed;
  inset: 0;
  z-index: 998;
  visibility: hidden;
  opacity: 0;
  transition: opacity 0.3s, visibility 0.3s;
}
.city-overview.show {
  visibility: visible;
  opacity: 1;
}

/* 面板：从底部上滑 */
.city-overview-panel {
  position: absolute;
  inset: 50rpx 0 0;
  border-radius: 24rpx 24rpx 0 0;
  background: rgba(15, 16, 20, 0.97);
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.city-overview.show .city-overview-panel {
  transform: translateY(0);
}

/* 拖拽区域 */
.co-drag-area {
  flex-shrink: 0;
}
.co-handle-bar {
  width: 88rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: rgba(255, 255, 255, 0.25);
  margin: 16rpx auto 0;
}

/* 顶部栏 */
.co-header {
  padding: 20rpx 40rpx 24rpx;
  flex-shrink: 0;
}
.co-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}

/* 滚动列表 */
.city-list {
  flex: 1;
  overflow: hidden;
  padding: 8rpx 0;
}

/* 城市卡片 */
.city-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 24rpx 16rpx;
  padding: 28rpx 28rpx 28rpx 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  border-left: 4rpx solid transparent;
  box-sizing: border-box;
}
.city-card-active {
  border-left-color: var(--theme, #1296db);
}

/* 左侧：城市名 + 天气文字 + 省市 */
.city-card-left {
  flex: 1;
  min-width: 0;
  padding-right: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.city-card-name-row {
  display: flex;
  align-items: center;
}
.city-located-dot {
  font-size: 18rpx;
  margin-right: 4rpx;
  color: var(--theme, #1296db);
  line-height: 1;
}
.city-card-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.city-card-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  white-space: nowrap;
}
.city-card-region {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 右侧：图标 + 当前温度 + 高低温 */
.city-card-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  flex-shrink: 0;
}
.city-card-icon {
  font-size: 52rpx;
  line-height: 1;
}
.city-card-temp {
  font-size: 44rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1.1;
}
.city-card-hilo {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.2;
}

/* 骨架屏 */
.city-card-skeleton {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}
.ck-bar {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 6rpx;
}
.ck-bar-icon { width: 48rpx; height: 48rpx; border-radius: 8rpx; }
.ck-bar-temp { width: 72rpx; height: 36rpx; }
.ck-bar-text { width: 80rpx; height: 24rpx; }

/* 天气图标颜色（对应 iconColor.wxs 的 category） */
.ic-sunny { color: #FFD54F; }
.ic-partlyCloudy { color: #FFA726; }
.ic-cloudy { color: #90A4AE; }
.ic-overcast { color: #78909C; }
.ic-thunder { color: #CE93D8; }
.ic-rainLight { color: #5BA3D9; }
.ic-rainHeavy { color: #5E9FD4; }
.ic-sleet { color: #80DEEA; }
.ic-snow { color: #E1F5FE; }
.ic-snowHeavy { color: #E1F5FE; }
.ic-fog { color: #B0BEC5; }
.ic-haze { color: #A1887F; }
.ic-sand { color: #D7CCC8; }
.ic-typhoon { color: #EF5350; }
.ic-hot { color: #FF7043; }
.ic-cold { color: #64B5F6; }
.ic-default { color: rgba(255, 255, 255, 0.7); }
