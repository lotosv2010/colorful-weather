<!--components/weather30-card/index.wxml-->
<wxs src="../../utils/iconColor.wxs" module="ic" />
<wxs src="../../utils/moonPhase.wxs" module="mp" />
<wxs src="../../utils/fmt.wxs" module="fmt" />

<view class="detail-card {{active ? 'detail-card-active' : ''}}">
  <!-- 第1行: 周 + 日期 -->
  <view class="card-row row-date">
    <text class="date-text">{{item.week}} {{item.dateLabel}}</text>
  </view>

  <!-- 第2行: icon + 最高～最低温度 -->
  <view class="card-row row-main">
    <i class="qi-{{fmt.safe(item.iconDay)}}-fill icon-color-{{ic.category(fmt.safe(item.iconDay))}} card-icon"></i>
    <text class="temp-max">{{fmt.safe(item.tempMax)}}°</text>
    <text class="temp-sep">～</text>
    <text class="temp-min">{{fmt.safe(item.tempMin)}}°</text>
  </view>

  <!-- 第3行: 升降温 + 白天/晚间天气 + 最高最低 -->
  <view class="card-row row-desc">
    <text class="desc-text" wx:if="{{item.tempDesc}}">{{item.tempDesc}}，白天{{fmt.safe(item.textDay)}}，最高{{fmt.safe(item.tempMax)}}°；晚间{{fmt.safe(item.textNight)}}，最低{{fmt.safe(item.tempMin)}}°。</text>
    <text class="desc-text" wx:else>白天{{fmt.safe(item.textDay)}}，最高{{fmt.safe(item.tempMax)}}°；晚间{{fmt.safe(item.textNight)}}，最低{{fmt.safe(item.tempMin)}}°。</text>
  </view>

  <!-- 第4行: 风速 · 降水量 · 湿度 -->
  <view class="card-row">
    <view class="cell cell-l">
      <text class="cell-val">{{fmt.safe(item.windSpeedDay)}}km/h</text>
      <text class="cell-label">{{fmt.safe(item.windDirDay)}}</text>
    </view>
    <view class="cell cell-c">
      <text class="cell-val">{{fmt.safe(item.precip)}}mm</text>
      <text class="cell-label">降水量</text>
    </view>
    <view class="cell cell-r">
      <text class="cell-val">{{fmt.safe(item.humidity)}}%</text>
      <text class="cell-label">湿度</text>
    </view>
  </view>

  <!-- 第5行: 紫外线 · 日出 · 日落 -->
  <view class="card-row" wx:if="{{item.sunrise}}">
    <view class="cell cell-l">
      <text class="cell-val">{{fmt.uvText(item.uvIndex)}}</text>
      <text class="cell-label">紫外线</text>
    </view>
    <view class="cell cell-c">
      <text class="cell-val">{{item.sunrise}}</text>
      <text class="cell-label">日出</text>
    </view>
    <view class="cell cell-r">
      <text class="cell-val">{{item.sunset}}</text>
      <text class="cell-label">日落</text>
    </view>
  </view>

  <!-- 第6行: 月相 · 月升 · 月落 -->
  <view class="card-row" wx:if="{{item.moonPhase}}">
    <view class="cell cell-l">
      <text class="cell-val moon-emoji">{{mp.emoji(item.moonPhaseIcon)}}</text>
      <text class="cell-label">{{mp.name(item.moonPhaseIcon)}}</text>
    </view>
    <view class="cell cell-c">
      <text class="cell-val">{{item.moonrise}}</text>
      <text class="cell-label">月升</text>
    </view>
    <view class="cell cell-r">
      <text class="cell-val">{{item.moonset}}</text>
      <text class="cell-label">月落</text>
    </view>
  </view>

  <!-- 第7行: 空气质量 -->
  <view class="card-row" wx:if="{{item.air}}">
    <text class="cell-label">空气质量</text>
    <view class="air-tag" style="background: {{item.air.color}}">
      <text class="air-aqi" style="color: {{item.air.textColor}}">{{item.air.aqiDisplay || item.air.aqi}}</text>
    </view>
    <text class="air-category">{{item.air.category}}</text>
  </view>
</view>
