/* components/temp/index.wxss */
.weather-header {
  background-color: rgb(34, 37, 48);
  padding: 0 15px 15px;
  border-radius: 15px;
}
.weather-handle {
  padding: 20rpx 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.weather-handle-bar {
  width: 88rpx;
  height: 8rpx;
  background-color: rgba(255, 255, 255, 0.45);
  border-radius: 4rpx;
}
.weather-header-date {
  font-size: 0.8rem;
  color: rgb(181, 187, 204);
  display: flex;
  width: 100%;
  align-items: center;
  justify-content: flex-end;
}
.weather-header-refresh {
  width: 1rem;
  height: 1rem;
  margin-left: 5px;
}
.weather-header-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: rgb(181, 187, 204);
}
.weather-header-city {
  font-size: 1.5rem;
}
.weather-header-main {
  height: 4.5rem;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 20px;
}
.weather-header-svg {
  font-size: 4.5rem;
}
.weather-header-left {
  height: 100%;
  font-size: 2rem;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  margin-left: 10px;
  color: #fff;
}
.weather-header-temp {
  height: 2rem;
  line-height: 2rem;
  position: relative;
}
.weather-header-unit {
  font-size: 1rem;
  height: 1rem;
  line-height: 1rem;
  position: absolute;
  top: 0px;
  right: -12px;
  margin-left: 5px;
}
.weather-header-text {
  font-size: 1.2rem;
}
.weather-alert {
  display: flex;
  align-items: center;
  background-color: rgb(46, 48, 61);
  border-radius: 10px;
  padding: 12px 16px;
  width: 100%;
  box-sizing: border-box;
  margin: 10px 0 0;
}
.weather-alert-icon {
  margin-right: 8px;
  font-size: 0.85rem;
  color: #ffb366;
}
.weather-alert-text {
  flex: 1;
  font-size: 0.8rem;
  color: #e0e0e0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.weather-alert-arrow {
  margin-left: 8px;
  font-size: 1rem;
  color: rgb(181, 187, 204);
}
.weather-entry {
  display: flex;
  align-items: center;
  background-color: rgb(46, 48, 61);
  border-radius: 10px;
  padding: 12px 16px;
  width: 100%;
  box-sizing: border-box;
  margin: 10px 0 0;
}
.weather-entry-icon {
  margin-right: 8px;
  font-size: 0.85rem;
  color: #5BA3D9;
}
.weather-entry-text {
  flex: 1;
  font-size: 0.8rem;
  color: #e0e0e0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.weather-entry-arrow {
  margin-left: 8px;
  font-size: 1rem;
  color: rgb(181, 187, 204);
}
.weather-entry-typhoon .weather-entry-icon {
  color: #FF9800;
}
.weather-header-desc {
  font-size: 0.8rem;
  text-align: center;
  margin-top: 15px;
  font-weight: 300;
  color: #A6A9AD;
}
.weather-header-other {
  background-color: rgb(46, 48, 61);
  width: 100%;
  height: 12rem;
  box-sizing: border-box;
  border-radius: 10px;
  display: flex;
  font-size: 0.8rem;
  padding: 20px;
  margin: 10px 0;
}
.weather-header-other-left{
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 30%;
  height: 100%;
  color: #fff;
} 
.weather-header-other-left .weather-header-fxd {
  font-size: 3rem;
  margin-bottom: 20px;
  margin-left: 30px;
}
.weather-header-other-right {
  display: flex;
  flex-direction: column;
  flex: 1;
}
.weather-header-other-right .row {
  display: flex;
  flex: 1;
}
.weather-header-other-right .grid{
  width: 50%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}
.weather-header-other-right .grid .label {
  color: #fff;
}
.weather-header-other-right .grid .value {
  position: relative;
  display: flex;
  flex-direction: column;
}
.weather-header-other-right .grid .unit {
  position: absolute;
  top: 0px;
  right: -5px;
  font-size: 0.5rem;
}