<!--components/temp/index.wxml-->
<wxs src="/utils/iconColor.wxs" module="ic" />
<wxs src="/utils/tempUnit.wxs" module="tu" />
<view class="weather-header">
  <view class="weather-handle">
    <view class="weather-handle-bar"></view>
  </view>
  <view class="weather-header-date" bindtap="getNow">
    <view>{{ date }} </view>
    <weather-icon class="weather-header-refresh" colors="{{['rgb(181, 187, 204)']}}" src="/static/icons/refresh.svg" />
  </view>
  <view class="weather-header-container">
    <view class="weather-header-main">
      <i class="weather-header-svg icon-color-{{ic.category(weather.icon || 100)}} qi-{{weather.icon || 100}}-fill"></i>
      <view class="weather-header-left">
        <view class="weather-header-temp">
          {{ tu.fmt(weather.temp, tempUnit) }}
          <text class="weather-header-unit">°</text>
        </view>
        <view class="weather-header-text">{{ weather.text }}</view>
      </view>
    </view>
    <view class="weather-header-desc">{{desc}}</view>
    <view wx:if="{{alerts.length}}" class="weather-alert" bindtap="gotoWarning">
      <i class="weather-alert-icon qi-9999"></i>
      <text class="weather-alert-text">{{alerts.length > 1 ? '多种天气预警正在发生' : alerts[0].headline}}</text>
      <text class="weather-alert-arrow">›</text>
    </view>
    <view class="weather-entry" wx:if="{{showMinutelyEntry}}" bindtap="onMinutelyTap">
      <i class="weather-entry-icon qi-{{minutelyType === 'snow' ? 499 : 399}}-fill"></i>
      <text class="weather-entry-text">{{minutelySummary || '分钟级雨量'}}</text>
      <text class="weather-entry-arrow">›</text>
    </view>
    <view class="weather-entry weather-entry-typhoon" wx:if="{{showTyphoonEntry}}" bindtap="onTyphoonTap">
      <i class="weather-entry-icon qi-1803"></i>
      <text class="weather-entry-text">{{typhoonSummary || '台风路径'}}</text>
      <text class="weather-entry-arrow">›</text>
    </view>
    <view class="weather-header-other">
      <view class="weather-header-other-left">
        <i class="weather-header-fxd qi-2150"></i>
        <text>{{weather.windDir}} {{weather.windScale}}级</text>
        <text>{{weather.windSpeed}}km/h</text>
      </view>
      <view class="weather-header-other-right">
        <view class="row">
          <view class="grid">
            <text class="value">{{weather.humidity}}%</text>
            <text class="label">湿度</text>
          </view>
          <view class="grid">
            <text class="value">{{uv}}</text>
            <text class="label">紫外线</text>
          </view>
        </view>
        <view class="row">
          <view class="grid">
            <text class="value">
              <text>{{ tu.fmt(weather.feelsLike, tempUnit) }}</text>
              <text class="unit">°</text>
            </text>
            <text class="label">体感温度</text>
          </view>
          <view class="grid">
            <text class="value">{{weather.vis}}km</text>
            <text class="label">能见度</text>
          </view>
        </view>
        <view class="row">
          <view class="grid">
            <text class="value">{{weather.precip}}mm</text>
            <text class="label">降水量</text>
          </view>
          <view class="grid">
            <text class="value">{{weather.pressure}}pha</text>
            <text class="label">大气压</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>