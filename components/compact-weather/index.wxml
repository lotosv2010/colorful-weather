<!--components/compact-weather/index.wxml-->
<wxs src="/utils/iconColor.wxs" module="ic" />
<wxs src="/utils/tempUnit.wxs" module="tu" />
<view class="compact" style="{{weatherBgStyle}}">
  <view class="compact-top">
    <view class="compact-location" catchtap="onShowSelector">
      <icon class="compact-location-icon" type="search" color="#fff" size="24"></icon>
      <view class="compact-location-text">{{ locationLabel || '定位中…' }}</view>
    </view>
    <view class="compact-date">
      <view>{{ dateNow }}</view>
      <weather-icon
        class="compact-refresh"
        colors="{{['rgb(181, 187, 204)']}}"
        src="/static/icons/refresh.svg"
        catchtap="onRefresh"
      />
    </view>
  </view>
  <!-- 天气主区域：骨架屏 / 错误状态 / 真实内容 -->
  <block wx:if="{{!loading && !errorMsg}}">
    <view class="weather-header-container">
      <view class="weather-header-main">
        <i class="weather-header-svg icon-color-{{ic.category(weather.icon || 100)}} qi-{{weather.icon || 100}}-fill"></i>
        <view class="weather-header-left">
          <view class="weather-header-temp">{{ tu.fmt(weather.temp, tempUnit) }}°</view>
          <view class="weather-header-text">{{ weather.text || '' }}</view>
        </view>
      </view>
      <view class="weather-header-desc">{{ desc || '' }}</view>
    </view>
  </block>
  <block wx:elif="{{errorMsg}}">
    <error-state compact errorMsg="{{errorMsg}}" bind:retry="onRetry" />
  </block>
  <block wx:else>
    <view class="sk-compact">
      <view class="sk-compact-main">
        <view class="sk-circle"></view>
        <view class="sk-compact-left">
          <view class="sk-bar sk-bar-temp"></view>
          <view class="sk-bar sk-bar-text"></view>
        </view>
      </view>
      <view class="sk-bar sk-bar-desc"></view>
    </view>
  </block>
</view>
