<view class="sheet">
  <!-- 紧凑层：始终位于底部，不再随展开 fade -->
  <view
    class="compact-layer"
    style="{{weatherBg ? 'background-color:' + weatherBg : ''}}"
    bindtouchstart="onTouchStart"
    catchtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
    bindtouchcancel="onTouchEnd"
  >
    <view class="compact-above"><slot name="compact-above"></slot></view>
    <view class="compact-handle" style="{{weatherBg ? 'background-color:' + weatherBg : ''}}">
      <view class="handle-bar"></view>
    </view>
    <slot name="compact"></slot>
  </view>

  <!-- 全屏层：从下向上滑入，bg alpha 随 progress 渐深 -->
  <view
    class="full-layer {{dragging ? 'dragging' : ''}} {{expanded ? 'full-active' : ''}}"
    style="transform: translateY({{(1 - progress) * 100}}%); background-color: rgba(20, 22, 30, {{progress * 0.98}});"
  >
    <view
      class="full-handle"
      bindtouchstart="onTouchStart"
      catchtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
      bindtouchcancel="onTouchEnd"
    ></view>
    <scroll-view
      scroll-y="{{expanded}}"
      enhanced="{{true}}"
      show-scrollbar="{{false}}"
      bounces="{{false}}"
      class="full-scroll"
      bindscroll="onScroll"
      bindtouchstart="onScrollTouchStart"
      bindtouchmove="onScrollTouchMove"
      bindtouchend="onScrollTouchEnd"
      bindtouchcancel="onScrollTouchEnd"
    >
      <slot name="full"></slot>
    </scroll-view>
  </view>
</view>
