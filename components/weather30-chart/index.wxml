<!--components/weather30-chart/index.wxml-->
<wxs src="../../utils/iconColor.wxs" module="ic" />
<wxs src="../../utils/fmt.wxs" module="fmt" />
<view class="chart-wrapper">
  <scroll-view scroll-x class="chart-scroll" enhanced show-scrollbar="{{false}}">
    <view class="chart-content" style="width: {{totalWidth}}px">
      <!-- Canvas 折线层 -->
      <canvas type="2d" id="tempCanvas" class="temp-canvas"
        width="{{totalWidth}}" height="{{canvasHeight}}"
        style="width: {{totalWidth}}px; height: {{canvasHeight}}px; top: {{canvasTop}}px">
      </canvas>
      <!-- 每个 item -->
      <view class="chart-item {{selectedIndex === index ? 'active' : ''}}"
        wx:for="{{daily}}" wx:key="fxDate"
        style="width: {{itemWidth}}px"
        bindtap="onSelectItem" data-index="{{index}}">
        <text class="chart-week">{{item.week}}</text>
        <text class="chart-day">{{item.month}}月{{item.day}}日</text>
        <i class="qi-{{fmt.safe(item.iconDay)}}-fill icon-color-{{ic.category(fmt.safe(item.iconDay))}} chart-icon"></i>
        <text class="chart-temp-max">{{fmt.safe(item.tempMax)}}°</text>
        <view class="chart-line-space" style="height: {{canvasHeight}}px"></view>
        <text class="chart-temp-min">{{fmt.safe(item.tempMin)}}°</text>
        <i class="qi-{{fmt.safe(item.iconNight)}}-fill icon-color-{{ic.category(fmt.safe(item.iconNight))}} chart-icon"></i>
        <view class="chart-air-tag" wx:if="{{item.air}}"
          style="background: {{item.air.color}}">
          <text style="color: {{item.air.textColor}}">{{item.air.category}}</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>

<!-- 选中项详情卡片 -->
<view class="chart-detail" wx:if="{{daily[selectedIndex]}}">
  <weather30-card item="{{daily[selectedIndex]}}" />
</view>
