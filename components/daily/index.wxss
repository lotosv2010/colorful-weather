/* components/daily/index.wxss */
.weather-daily {
  background-color: rgb(34, 37, 48);
  padding: 15px;
  border-radius: 15px;
  margin: 10px 0;
  box-sizing: border-box;
}
.weather-daily-header {
  font-size: 0.8rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}
.weather-daily-header .right {
  color: rgb(181, 187, 204);
}
.weather-daily-header .action.more {
  color: var(--theme, rgb(68, 179, 255));
  text-decoration: none;
}
.weather-daily-item {
  background-color: rgb(46, 48, 61);
  box-sizing: border-box;
  border-radius: 10px;
  font-size: 0.7rem;
  display: flex;
  align-items: center;
  padding: 10px;
  margin-bottom: 10px;
}
.weather-daily-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 8px;
}
.weather-daily-date .week {
  font-size: 0.9rem;
}
.weather-daily-date .time {
  font-size: 0.7rem;
}
.weather-daily-icon {
  font-size: 1.5rem;
  flex-shrink: 0;
  margin: 0 16px;
}
/* 进度条区域：两侧留 32px 给温度标签 */
.weather-daily-temp-bar {
  flex: 1;
  position: relative;
  height: 4px;
  min-width: 0;
  margin: 0 32px;
  overflow: visible;
}
.weather-daily-bar {
  position: absolute;
  top: 0;
  height: 100%;
  border-radius: 5px;
  background: linear-gradient(to right, rgb(238, 141, 114), rgb(86, 110, 255));
}
/* 温度标签绝对定位贴 bar 两端 */
.weather-daily-temp {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  align-items: flex-start;
  white-space: nowrap;
}
.weather-daily-temp-max {
  right: 100%;
  margin-right: 4px;
}
.weather-daily-temp-min {
  left: 100%;
  margin-left: 4px;
}
.weather-daily-temp .value {
  font-size: 0.75rem;
}
.weather-daily-temp .unit {
  font-size: 0.65rem;
  line-height: 0.75rem;
}
