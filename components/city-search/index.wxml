<wxs src="../../utils/iconColor.wxs" module="ic" />
<view class="city-search {{show ? 'show' : ''}}" catchtap="onClose">
  <view class="panel" catchtap="noop">
    <view wx:if="{{show}}" class="search-bar">
      <view class="input-wrap">
        <icon type="search" size="16" color="#999" />
        <input
          class="input"
          placeholder="输入城市名/拼音"
          placeholder-style="color:#999"
          value="{{keyword}}"
          bindinput="onInput"
          confirm-type="search"
          focus="{{show}}"
        />
        <view wx:if="{{keyword}}" class="clear" catchtap="onClear">×</view>
      </view>
      <view class="cancel" catchtap="onClose">取消</view>
    </view>

    <scroll-view class="body" scroll-y>
      <!-- 搜索状态 -->
      <view wx:if="{{loading}}" class="tip">搜索中…</view>
      <view wx:elif="{{errorMsg}}" class="tip">{{errorMsg}}</view>

      <!-- 搜索结果 -->
      <block wx:if="{{keyword && results.length}}">
        <view class="section-title">搜索结果</view>
        <view
          wx:for="{{results}}"
          wx:key="id"
          class="result-item"
          data-city="{{item}}"
          catchtap="onPick"
        >
          <view class="name">{{item.name}}</view>
          <view class="path">{{item.adm2}} · {{item.adm1}} · {{item.country}}</view>
        </view>
      </block>

      <!-- 热门城市 -->
      <block wx:if="{{!keyword && hotList.length}}">
        <view class="section-title">热门城市</view>
        <view class="hot-grid">
          <view
            wx:for="{{hotList}}"
            wx:key="id"
            class="hot-item"
            data-city="{{item}}"
            catchtap="onPick"
          >{{item.name}}</view>
        </view>
      </block>

      <!-- 搜索历史 -->
      <block wx:if="{{!keyword && historyList.length}}">
        <view class="section-head">
          <view class="section-title">最近</view>
          <view class="section-action" catchtap="onClearHistory">清除</view>
        </view>
        <view class="history-list">
          <view
            wx:for="{{historyList}}"
            wx:key="id"
            class="history-item"
            data-city="{{item}}"
            catchtap="onPick"
          >
            <view class="row">
              <text class="weather-icon icon-color-{{ic.category(item.weather.icon || 100)}} qi-{{item.weather.icon || 100}}-fill"></text>
              <text class="city-name">{{item.name}}</text>
            </view>
            <view class="row sub">
              <text class="weather-temp">{{item.weather.temp || '--'}}°</text>
              <text class="city-path">{{item.adm1}} · {{item.country}}</text>
            </view>
          </view>
        </view>
      </block>
    </scroll-view>
  </view>
</view>
