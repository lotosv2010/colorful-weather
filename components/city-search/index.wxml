<wxs src="../../utils/iconColor.wxs" module="ic" />
<wxs src="../../utils/tempUnit.wxs" module="tu" />
<view class="city-search {{show ? 'show' : ''}}" catchtap="onClose" catchtouchmove="noop">
  <view class="panel" style="{{panelStyle}}" catchtap="noop">
    <!-- 拖拽把手 -->
    <view class="cs-drag-area"
      bindtouchstart="onDragStart"
      bindtouchmove="onDragMove"
      bindtouchend="onDragEnd"
    >
      <view class="cs-handle-bar"></view>
    </view>

    <view wx:if="{{show}}" class="search-bar">
      <view class="input-wrap">
        <icon type="search" size="16" color="#999" />
        <input
          class="input"
          placeholder="输入城市名/拼音"
          placeholder-style="color:#999"
          value="{{keyword}}"
          bindinput="onInput"
          confirm-type="search"
          focus="{{show}}"
          adjust-position="{{false}}"
        />
        <view wx:if="{{keyword}}" class="clear" catchtap="onClear">×</view>
      </view>
    </view>

    <scroll-view class="body" scroll-y enhanced show-scrollbar="{{false}}">
      <!-- 搜索状态 -->
      <view wx:if="{{loading}}" class="tip">搜索中…</view>
      <view wx:elif="{{errorMsg}}" class="tip">{{errorMsg}}</view>

      <!-- 当前定位 -->
      <block wx:if="{{!keyword && currentItem}}">
        <view class="section-title">当前定位</view>
        <view class="history-list">
          <view class="history-item">
            <view class="history-main" catchtap="onPickCurrent">
              <view class="row">
                <i class="weather-icon icon-color-{{ic.category(currentItem.weather.icon || 100)}} qi-{{currentItem.weather.icon || 100}}-fill"></i>
                <text class="city-name">{{currentItem.name}}</text>
                <text class="pin-tag">定位</text>
              </view>
              <view class="row sub">
                <text class="weather-temp">{{tu.fmt(currentItem.weather.temp, tempUnit)}}°</text>
                <text class="city-path">{{currentItem.adm1}}{{currentItem.adm2 && currentItem.adm2 !== currentItem.adm1 ? ' · ' + currentItem.adm2 : ''}}</text>
              </view>
            </view>
          </view>
        </view>
      </block>

      <!-- 搜索结果 -->
      <block wx:if="{{keyword && results.length}}">
        <view class="section-title">搜索结果</view>
        <view
          wx:for="{{results}}"
          wx:key="id"
          class="result-item"
        >
          <view class="result-main" data-city="{{item}}" catchtap="onPick">
            <view class="name">{{item.name}}</view>
            <view class="path">{{item.adm2}} · {{item.adm1}} · {{item.country}}</view>
          </view>
          <view
            class="star {{favoriteIds[item.id] ? 'star-on' : ''}}"
            data-city="{{item}}"
            catchtap="onToggleFavorite"
          >{{favoriteIds[item.id] ? '★' : '☆'}}</view>
        </view>
      </block>

      <!-- 收藏城市 -->
      <block wx:if="{{!keyword && favoritesList.length}}">
        <view class="section-title">我的收藏</view>
        <view class="history-list">
          <view
            wx:for="{{favoritesList}}"
            wx:key="id"
            class="history-item"
          >
            <view class="history-main" data-city="{{item}}" catchtap="onPick">
              <view class="row">
                <i class="weather-icon icon-color-{{ic.category(item.weather.icon || 100)}} qi-{{item.weather.icon || 100}}-fill"></i>
                <text class="city-name">{{item.name}}</text>
                <text wx:if="{{item.pinned}}" class="pin-tag">置顶</text>
              </view>
              <view class="row sub">
                <text class="weather-temp">{{tu.fmt(item.weather.temp, tempUnit)}}°</text>
                <text class="city-path">{{item.adm1}}{{item.adm2 && item.adm2 !== item.adm1 ? ' · ' + item.adm2 : ''}}</text>
                <text wx:if="{{item.tzDiff}}" class="tz-tag">{{item.tzDiff}}</text>
              </view>
            </view>
            <view
              class="star star-on"
              data-city="{{item}}"
              catchtap="onToggleFavorite"
            >★</view>
          </view>
        </view>
      </block>

      <!-- 热门城市 -->
      <block wx:if="{{!keyword && hotList.length}}">
        <view class="section-title">热门城市</view>
        <view class="hot-grid">
          <view
            wx:for="{{hotList}}"
            wx:key="id"
            class="hot-item"
            data-city="{{item}}"
            catchtap="onPick"
          >{{item.name}}</view>
        </view>
      </block>

      <!-- 搜索历史 -->
      <block wx:if="{{!keyword && historyList.length}}">
        <view class="section-head">
          <view class="section-title">最近</view>
          <view class="section-action" catchtap="onClearHistory">清除</view>
        </view>
        <view class="history-list">
          <view
            wx:for="{{historyList}}"
            wx:key="id"
            class="history-item"
          >
            <view class="history-main" data-city="{{item}}" catchtap="onPick">
              <view class="row">
                <i class="weather-icon icon-color-{{ic.category(item.weather.icon || 100)}} qi-{{item.weather.icon || 100}}-fill"></i>
                <text class="city-name">{{item.name}}</text>
              </view>
              <view class="row sub">
                <text class="weather-temp">{{tu.fmt(item.weather.temp, tempUnit)}}°</text>
                <text class="city-path">{{item.adm1}} · {{item.country}}</text>
              </view>
            </view>
            <view
              class="star {{favoriteIds[item.id] ? 'star-on' : ''}}"
              data-city="{{item}}"
              catchtap="onToggleFavorite"
            >{{favoriteIds[item.id] ? '★' : '☆'}}</view>
          </view>
        </view>
      </block>

      <!-- 底部安全距离 -->
      <view style="height: env(safe-area-inset-bottom, 0);"></view>
    </scroll-view>
  </view>
</view>
