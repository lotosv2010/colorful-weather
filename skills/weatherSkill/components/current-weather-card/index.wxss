.card { padding: 14px 16px 12px; background: linear-gradient(135deg, #1a2440, #253a60); border-radius: 12px; color: #fff; }
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
.city { font-size: 15px; font-weight: 600; }
.tag { font-size: 11px; color: rgba(255,255,255,.5); border: 1px solid rgba(255,255,255,.2); border-radius: 4px; padding: 1px 6px; }
.main { display: flex; align-items: flex-end; gap: 12px; margin-bottom: 12px; }
.temp-block { display: flex; align-items: baseline; gap: 8px; }
.temp { font-size: 48px; font-weight: 200; line-height: 1; }
.text { font-size: 16px; color: rgba(255,255,255,.85); }
.feels { font-size: 12px; color: rgba(255,255,255,.5); padding-bottom: 4px; }
.detail { display: flex; align-items: center; background: rgba(255,255,255,.08); border-radius: 8px; padding: 8px 0; }
.item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px; }
.label { font-size: 11px; color: rgba(255,255,255,.5); }
.val { font-size: 13px; font-weight: 500; }
.sep { width: 1px; height: 24px; background: rgba(255,255,255,.15); }
