.card { padding: 14px 16px 12px; background: linear-gradient(135deg, #1a2440, #253a60); border-radius: 12px; color: #fff; }
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.city { font-size: 15px; font-weight: 600; }
.tag { font-size: 11px; color: rgba(255,255,255,.5); border: 1px solid rgba(255,255,255,.2); border-radius: 4px; padding: 1px 6px; }
.grid { display: flex; flex-wrap: wrap; gap: 8px; }
.cell { width: calc(25% - 6px); background: rgba(255,255,255,.08); border-radius: 8px; padding: 10px 6px; display: flex; flex-direction: column; align-items: center; gap: 4px; box-sizing: border-box; }
.dot { width: 8px; height: 8px; border-radius: 50%; }
.label { font-size: 11px; color: rgba(255,255,255,.6); }
.cat { font-size: 13px; font-weight: 500; text-align: center; }
