.card { padding: 14px 16px 10px; background: linear-gradient(160deg, #1a1a2e, #16213e); border-radius: 12px; color: #fff; }
.header { display: flex; align-items: center; gap: 6px; margin-bottom: 12px; }
.city { font-size: 14px; font-weight: 600; flex: 1; }
.date-badge { font-size: 11px; color: rgba(255,255,255,.5); background: rgba(255,255,255,.08); border-radius: 4px; padding: 2px 6px; }
.tag { font-size: 11px; color: rgba(255,255,255,.4); border: 1px solid rgba(255,255,255,.15); border-radius: 4px; padding: 1px 6px; }

.temp-summary { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
.temp-min { font-size: 22px; font-weight: 300; color: #90caf9; }
.temp-max { font-size: 22px; font-weight: 300; color: #ef9a9a; }
.temp-divider { width: 1px; height: 20px; background: rgba(255,255,255,.2); }
.temp-label { font-size: 11px; color: rgba(255,255,255,.4); flex: 1; text-align: right; }

.aqi-summary { display: flex; align-items: baseline; gap: 8px; margin-bottom: 10px; }
.aqi-num { font-size: 28px; font-weight: 200; color: #a5d6a7; }
.aqi-cat { font-size: 12px; color: rgba(255,255,255,.55); }

.bars { display: flex; align-items: flex-end; gap: 2px; height: 56px; margin-bottom: 4px; }
.bar-col { flex: 1; display: flex; align-items: flex-end; height: 56px; }
.bar-bg { width: 100%; display: flex; align-items: flex-end; height: 56px; }
.bar { width: 100%; border-radius: 2px 2px 0 0; opacity: 0.85; }
.time-axis { display: flex; justify-content: space-between; }
.tl { font-size: 9px; color: rgba(255,255,255,.3); }
