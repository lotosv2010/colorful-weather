// 通用格式化工具（WXS 视图层运行）
var safe = function (val) {
  if (val == null) return '';
  if (typeof val !== 'object') return '' + val;
  if (Array.isArray(val)) return val.length ? safe(val[0]) : '';
  if (val.value != null) return '' + val.value;
  if (val.text != null) return '' + val.text;
  if (val.name != null) return '' + val.name;
  if (val.desc != null) return '' + val.desc;
  var keys = Object.keys(val);
  for (var i = 0; i < keys.length; i++) {
    var k = keys[i];
    if (typeof val[k] !== 'object' && val[k] != null) return '' + val[k];
  }
  return '';
};

var uvText = function (val) {
  var n = +val;
  if (isNaN(n)) return '' + val;
  if (n <= 2) return '最弱';
  if (n <= 4) return '弱';
  if (n <= 6) return '中等';
  if (n <= 9) return '强';
  return '很强';
};

module.exports = {
  safe: safe,
  uvText: uvText
};
