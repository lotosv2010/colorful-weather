// 月相 icon 编码 → emoji 映射
var emoji = {
  '800': '🌑', '801': '🌒', '802': '🌓', '803': '🌔',
  '804': '🌕', '805': '🌖', '806': '🌗', '807': '🌘'
};
var names = {
  '800': '新月', '801': '蛾眉月', '802': '上弦月', '803': '盈凸月',
  '804': '满月', '805': '亏凸月', '806': '下弦月', '807': '残月'
};

module.exports.emoji = function(icon) {
  return emoji['' + icon] || '';
};
module.exports.name = function(icon) {
  return names['' + icon] || '';
};
