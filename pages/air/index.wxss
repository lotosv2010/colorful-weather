/* pages/air/index.wxss */
page {
  background: #000;
  color: #fff;
}

.air-page {
  padding: 20rpx 24rpx 40rpx;
}

/* 加载/错误提示 */
.tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 80rpx 0;
}

/* 概览区块 */
.air-overview {
  background: rgb(34, 37, 48);
  border-radius: 15px;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.air-ring {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 12rpx solid #9BB365;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.aqi-value {
  font-size: 72rpx;
  font-weight: 300;
}

.aqi-category {
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.aqi-desc {
  font-size: 26rpx;
  color: #b5bbcc;
  line-height: 1.6;
  text-align: center;
  margin-bottom: 16rpx;
}

.aqi-primary {
  font-size: 24rpx;
  color: #A6A9AD;
}

.primary-value {
  color: #fff;
}

/* 通用卡片 */
.air-card {
  background: rgb(34, 37, 48);
  border-radius: 15px;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
  color: rgb(181, 187, 204);
}

.card-body {
  font-size: 26rpx;
  color: #d5d5d5;
  line-height: 1.6;
}

.advice-item {
  margin-bottom: 16rpx;
}

.advice-item:last-child {
  margin-bottom: 0;
}

.advice-label {
  font-size: 24rpx;
  color: #A6A9AD;
}

.advice-text {
  font-size: 26rpx;
  color: #d5d5d5;
  line-height: 1.6;
}

/* 污染物网格 */
.pollutant-grid {
  display: flex;
  flex-wrap: wrap;
}

.pollutant-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.pollutant-name {
  font-size: 24rpx;
  color: #A6A9AD;
  margin-bottom: 8rpx;
}

.pollutant-value {
  font-size: 36rpx;
  font-weight: 300;
  margin-bottom: 4rpx;
}

.pollutant-unit {
  font-size: 20rpx;
  color: #666;
}

/* 小时预报 */
.hourly-scroll {
  white-space: nowrap;
}

.hourly-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 140rpx;
  padding: 16rpx 0;
  background: rgb(17, 17, 21);
  border-radius: 16rpx;
  margin-right: 16rpx;
}

.hourly-time {
  font-size: 24rpx;
  color: #A6A9AD;
  margin-bottom: 12rpx;
}

.hourly-aqi {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.hourly-cat {
  font-size: 22rpx;
  color: #8C9AA5;
}

/* 每日预报 */
.daily-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.daily-item:last-child {
  border-bottom: none;
}

.daily-date {
  width: 140rpx;
  display: flex;
  flex-direction: column;
}

.daily-week {
  font-size: 28rpx;
}

.daily-day {
  font-size: 22rpx;
  color: #8C9AA5;
  margin-top: 4rpx;
}

.daily-info {
  flex: 1;
  display: flex;
  align-items: center;
}

.daily-aqi-badge {
  width: 80rpx;
  height: 48rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.daily-aqi {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.daily-cat {
  font-size: 26rpx;
  margin-right: 16rpx;
}

.daily-primary {
  font-size: 22rpx;
  color: #A6A9AD;
}
