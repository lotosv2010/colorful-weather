<!--pages/air/index.wxml-->
<view class="air-page">

  <!-- 头部城市信息 -->
  <page-header district="{{district}}" province="{{province}}" />

  <!-- 加载与错误状态 -->
  <view wx:if="{{loading}}" class="tip">加载中...</view>
  <view wx:elif="{{errorMsg}}" class="tip">{{errorMsg}}</view>

  <block wx:else>
    <!-- 概览信息 -->
    <view class="air-overview">
      <view class="air-ring">
        <canvas type="2d" id="aqiCanvas" class="aqi-canvas"></canvas>
        <text class="aqi-value">{{aqiDisplay || aqi}}</text>
      </view>
      <text class="aqi-category" style="color: {{levelColor}}">{{category}}</text>
      <text class="aqi-desc" wx:if="{{healthEffect}}">{{healthEffect}}</text>
      <view class="aqi-primary" wx:if="{{primary}}">
        <text class="primary-label">首要污染物：</text>
        <text class="primary-value">{{primary}}</text>
      </view>
      <!-- 污染物指标网格 -->
      <view class="overview-grid">
        <view class="overview-col" wx:for="{{pollutants}}" wx:key="key">
          <view class="overview-val">{{item.value}}</view>
          <progress class="overview-progress" border-radius="5" backgroundColor="#3D3F4A" activeColor="{{levelColor}}" percent="{{item.value}}" active stroke-width="3" />
          <view class="overview-label">{{item.name}}</view>
        </view>
      </view>
    </view>

    <!-- 健康建议 -->
    <view class="air-card" wx:if="{{generalAdvice || sensitiveAdvice}}">
      <view class="card-title">健康建议</view>
      <view class="advice-item" wx:if="{{generalAdvice}}">
        <text class="advice-label">一般人群：</text>
        <text class="advice-text">{{generalAdvice}}</text>
      </view>
      <view class="advice-item" wx:if="{{sensitiveAdvice}}">
        <text class="advice-label">敏感人群：</text>
        <text class="advice-text">{{sensitiveAdvice}}</text>
      </view>
    </view>

    <!-- 小时预报 -->
    <view class="air-card" wx:if="{{hourly.length}}">
      <view class="card-title">小时预报</view>
      <scroll-view class="hourly-scroll" scroll-x>
        <view class="hourly-item" wx:for="{{hourly}}" wx:key="time">
          <text class="hourly-time">{{item.time}}</text>
          <view class="hourly-ring" style="background: conic-gradient({{item.color || '#4caf50'}} {{item.pct}}%, #3D3F4A 0)">
            <view class="hourly-ring-inner">
              <text class="hourly-aqi">{{item.aqiDisplay || item.aqi}}</text>
            </view>
          </view>
          <text class="hourly-cat">{{item.category}}</text>
        </view>
      </scroll-view>
    </view>

    <!-- 每日预报 -->
    <view class="air-card" wx:if="{{daily.length}}">
      <view class="card-title">每日预报</view>
      <view class="daily-item" wx:for="{{daily}}" wx:key="date">
        <view class="daily-date">
          <text class="daily-week">{{item.week}}</text>
          <text class="daily-day">{{item.dateLabel}}</text>
        </view>
        <view class="daily-aqi-info">
          <text class="daily-aqi-name">{{item.name}}</text>
          <text class="daily-aqi-value">{{item.aqiDisplay || item.aqi}}</text>
        </view>
        <view class="daily-tag" style="background: {{item.color}}">
          <text class="daily-tag-text" style="color: {{item.textColor}}">{{item.category}}</text>
        </view>
      </view>
    </view>
  </block>
</view>
