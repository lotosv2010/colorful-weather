page {
  background-color: #000;
}

.page {
  min-height: 100vh;
  background: #000;
  padding: 24rpx 0 80rpx;
  box-sizing: border-box;
}

.section {
  background: rgb(34, 37, 48);
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 24rpx;
}

.section-tip {
  font-size: 24rpx;
  color: rgb(140, 148, 165);
  margin-top: 20rpx;
  line-height: 1.5;
}

/* 分段控件 */
.seg {
  display: flex;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  padding: 6rpx;
}
.seg-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: rgb(181, 187, 204);
  border-radius: 10rpx;
  transition: all .2s;
}
.seg-item-active {
  background: var(--theme);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,.25);
}

/* 主题色块 */
.theme-row {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
  margin-top: 20rpx;
}
.theme-chip {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 14rpx rgba(0,0,0,.4);
}
.theme-chip-active {
  transform: scale(1.08);
}
.theme-check {
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
}

/* 城市列表 */
.city-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.city-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}
.city-row:last-child {
  border-bottom: none;
}
.city-row-default {
  background: linear-gradient(90deg, rgba(255,255,255,.04), transparent);
}
.city-main {
  flex: 1;
  min-width: 0;
}
.city-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.city-sub {
  font-size: 24rpx;
  color: rgb(140, 148, 165);
  margin-top: 6rpx;
}
.badge-pin,
.badge-default,
.badge-tz {
  font-size: 20rpx;
  font-weight: 500;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}
.badge-pin {
  background: rgba(250, 140, 22, 0.18);
  color: #fa8c16;
}
.badge-default {
  background: var(--theme);
  color: #fff;
}
.badge-tz {
  background: rgba(255, 200, 90, 0.15);
  color: rgba(255, 200, 90, 0.9);
}

.city-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}
.city-btn {
  font-size: 24rpx;
  padding: 10rpx 18rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgb(181, 187, 204);
}
.city-btn-danger {
  background: rgba(212, 56, 13, 0.18);
  color: #ff7875;
}

.cache-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}
.cache-info {
  flex: 1;
  min-width: 0;
}
.cache-name {
  font-size: 28rpx;
  color: rgb(228, 232, 245);
}
.cache-sub {
  font-size: 22rpx;
  color: rgb(140, 148, 168);
  margin-top: 6rpx;
}
.cache-arrow {
  font-size: 36rpx;
  color: rgb(140, 148, 168);
  margin-left: 16rpx;
}
