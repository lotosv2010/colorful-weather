/* pages/typhoon/index.wxss */
page {
  background-color: #000;
}

.typhoon-page {
  padding: 20rpx 24rpx;
  color: #fff;
  height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.tip {
  text-align: center;
  color: #8C9AA5;
  font-size: 28rpx;
  padding: 60rpx 0;
}

/* 通用卡片 */
.storm-list-card,
.info-card,
.chart-card,
.forecast-card {
  background-color: rgb(34, 37, 48);
  border-radius: 15px;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.chart-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.card-title {
  font-size: 28rpx;
  color: #d5d5d5;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-subtitle {
  font-size: 22rpx;
  color: #8C9AA5;
  font-weight: normal;
}

/* 台风列表 */
.storm-list-scroll {
  white-space: nowrap;
}

.storm-chip {
  display: inline-flex;
  align-items: center;
  background-color: rgb(17, 17, 21);
  border-radius: 20px;
  padding: 10rpx 24rpx;
  margin-right: 16rpx;
  gap: 8rpx;
  border: 1px solid transparent;
}

.storm-chip.active {
  border-color: #FF9800;
}

.storm-chip.inactive {
  opacity: 0.5;
}

.storm-chip-name {
  font-size: 26rpx;
  color: #fff;
}

.storm-chip-tag {
  font-size: 20rpx;
  color: #FF9800;
  background-color: rgba(255, 152, 0, 0.15);
  border-radius: 8rpx;
  padding: 2rpx 10rpx;
}

/* 台风信息 */
.storm-type-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #fff;
  border-radius: 6rpx;
  padding: 4rpx 12rpx;
  font-weight: normal;
}

.info-grid {
  display: flex;
  gap: 16rpx;
}

.info-cell {
  flex: 1;
  background-color: rgb(17, 17, 21);
  border-radius: 10px;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.info-value {
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 6rpx;
}

.info-label {
  font-size: 20rpx;
  color: #8C9AA5;
}

/* 路径图 */
.map-wrapper {
  position: relative;
  flex: 1;
  min-height: 0;
}

.track-map {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 10px;
  overflow: hidden;
}

.map-ctrl {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  z-index: 10;
}

.map-ctrl-btn {
  width: 64rpx;
  height: 64rpx;
  background-color: rgba(34, 37, 48, 0.92);
  color: #fff;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(255, 255, 255, 0.12);
}

.map-ctrl-btn:first-child {
  border-radius: 10rpx 10rpx 0 0;
}

.map-ctrl-btn:last-child {
  border-radius: 0 0 10rpx 10rpx;
}

.map-ctrl-btn.locate {
  color: #FF9800;
  font-size: 30rpx;
  margin-top: 8rpx;
  border-radius: 10rpx;
}

/* 预报表格 */
.forecast-table {
  font-size: 24rpx;
}

.forecast-row {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.forecast-row.header {
  color: #8C9AA5;
  font-size: 22rpx;
}

.forecast-cell {
  flex: 1;
  display: flex;
  align-items: center;
}

.forecast-cell.time {
  flex: 1.5;
}

.type-dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}
