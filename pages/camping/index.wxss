/* pages/camping/index.wxss */
page {
  background: #0f1014;
  color: #fff;
  font-size: 28rpx;
}

.camping-page {
  min-height: 100vh;
  padding: 24rpx 24rpx env(safe-area-inset-bottom, 0);
  box-sizing: border-box;
}

/* ── 营地绿色 accent ──────────────────────────────── */
/* 注意：CSS 变量值中含 rgba() 在真机部分基础库下解析失败，
   故 camping-light / camping-border 直接内联到各选择器，不用变量传递 */
:root, .camping-page {
  --camping: #2a7b3e;
}

/* ── 城市选择卡 ──────────────────────────────────── */
.city-slot {
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-left: 4rpx solid var(--theme, #1296db);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.slot-filled {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.slot-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.slot-icon, .slot-add-icon {
  font-size: 48rpx;
  line-height: 1;
}

.slot-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.3;
}

.slot-region {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  margin-top: 4rpx;
}

.slot-change {
  font-size: 24rpx;
  color: var(--theme, #1296db);
  padding: 8rpx 20rpx;
  border: 1rpx solid rgba(18, 150, 219, 0.3);
  border-radius: 30rpx;
}

.slot-empty {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.slot-empty > view {
  flex: 1;
}

.slot-empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.7);
}

.slot-empty-sub {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
  margin-top: 6rpx;
}

.slot-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* ── 区块标签 ────────────────────────────────────── */
.section-label {
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.4);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin: 4rpx 0 14rpx;
}

/* ── 营地 POI chips ───────────────────────────────── */
.poi-scroll {
  margin-bottom: 20rpx;
  overflow: hidden;
}

.poi-list {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
  padding: 4rpx 0 8rpx;
  width: max-content;
}

.poi-chip {
  display: flex;
  flex-direction: column;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 16rpx;
  min-width: 160rpx;
  max-width: 280rpx;
  box-sizing: border-box;
  transition: background 0.15s;
}

.poi-chip-active {
  background: rgba(42, 123, 62, 0.15);
  border-color: rgba(42, 123, 62, 0.35);
}

.poi-chip-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 240rpx;
}

.poi-chip-addr {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 240rpx;
}

.poi-chip.poi-chip-active .poi-chip-name {
  color: #6fcf8a;
}

/* 骨架 chip */
.sk-chip {
  width: 160rpx;
  height: 72rpx;
  justify-content: center;
}

/* POI 空状态 */
.poi-empty {
  padding: 20rpx 0;
  margin-bottom: 12rpx;
}
.poi-empty-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.35);
}

/* ── 7天日期选择条 ────────────────────────────────── */
.date-scroll {
  margin-bottom: 20rpx;
  overflow: hidden;
}

.date-list {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  padding: 4rpx 0 8rpx;
  width: max-content;
}

.date-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  min-width: 100rpx;
  gap: 6rpx;
}

.date-card-active {
  background: rgba(42, 123, 62, 0.15);
  border-color: rgba(42, 123, 62, 0.35);
}

.date-week {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
}
.date-card-active .date-week {
  color: #6fcf8a;
}
.date-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}
.date-icon {
  font-size: 36rpx;
}
.date-temp {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* ── 通用卡片 ────────────────────────────────────── */
.camping-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(42, 123, 62, 0.28);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.card-title {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 20rpx;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.card-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card-note {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* ── 露营评分卡 ──────────────────────────────────── */
.advice-card {
  border-top: 4rpx solid;
}

.advice-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.advice-icon {
  font-size: 52rpx;
  line-height: 1;
}

.advice-main {
  flex: 1;
}

.advice-label {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.3;
}

.advice-date {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 4rpx;
}

.advice-score-badge {
  padding: 8rpx 18rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 700;
}

/* 夜间温度行 */
.night-temp-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(42, 123, 62, 0.12);
  border: 1rpx solid rgba(42, 123, 62, 0.25);
  border-radius: 12rpx;
  padding: 14rpx 20rpx;
  margin-bottom: 16rpx;
}

.night-temp-icon {
  font-size: 32rpx;
}

.night-temp-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  flex: 1;
}

.night-temp-val {
  font-size: 30rpx;
  font-weight: 700;
  color: #6fcf8a;
}

.night-temp-tag {
  font-size: 18rpx;
  color: #2a7b3e;
  background: rgba(42, 123, 62, 0.2);
  border: 1rpx solid rgba(42, 123, 62, 0.4);
  border-radius: 8rpx;
  padding: 4rpx 10rpx;
}

/* 提示列表 */
.advice-tips {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.advice-tip-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.tip-dot {
  color: rgba(255, 255, 255, 0.4);
  font-size: 28rpx;
  line-height: 1.4;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.5;
}

/* ── 天气详情卡 ──────────────────────────────────── */
.weather-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.weather-icon-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.weather-icon {
  font-size: 64rpx;
}

.weather-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.weather-temp-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.temp-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.temp-sub-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}

.night-label {
  color: #6fcf8a;
}

.temp-high {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.temp-sep {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.2);
  margin-bottom: 4rpx;
}

.temp-low {
  font-size: 48rpx;
  font-weight: 700;
  color: #6fcf8a;
}

.detail-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 0;
}

.detail-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.detail-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}

.detail-val {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

/* ── 生活指数卡 ──────────────────────────────────── */
.index-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.index-item {
  width: calc(50% - 10rpx);
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.index-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.index-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  flex: 1;
}

.index-cat {
  font-size: 24rpx;
  font-weight: 600;
}

.indices-na-card {
  border: 1rpx dashed rgba(42, 123, 62, 0.2);
  background: transparent;
}

.indices-na-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  text-align: center;
  display: block;
}

/* ── 空气质量卡 ──────────────────────────────────── */
.air-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.aqi-badge {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.aqi-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.aqi-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.7);
}

.air-cat {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
}

.air-sub {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  margin-top: 8rpx;
  line-height: 1.5;
}

/* ── 空状态 ──────────────────────────────────────── */
.empty-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  line-height: 1;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.7);
}

.empty-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.35);
  text-align: center;
  line-height: 1.6;
}

/* ── 骨架屏 ──────────────────────────────────────── */
.sk-card-wrap {
  padding: 28rpx 24rpx;
}

.sk-bar {
  height: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 8rpx;
  animation: sk-shimmer 1.4s ease-in-out infinite;
}
.sk-lg { width: 70%; }
.sk-md { width: 50%; }
.sk-sm { width: 40%; }
.sk-xs { width: 60%; height: 16rpx; }

.sk-circle-sm {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  animation: sk-shimmer 1.4s ease-in-out infinite;
}

.sk-date {
  pointer-events: none;
}

@keyframes sk-shimmer {
  0% { opacity: 0.5; }
  50% { opacity: 1; }
  100% { opacity: 0.5; }
}
