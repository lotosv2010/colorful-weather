/* pages/life/index.wxss */
page {
  background: #000;
  color: #fff;
}
.life-page {
  padding: 20rpx 24rpx 40rpx;
}

/* 顶部 tab：横向滑动 */
.tabs {
  white-space: nowrap;
  padding: 16rpx 0 24rpx;
}
.tab {
  display: inline-flex;
  vertical-align: top;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 0 18rpx;
}
.tab-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #2e303d;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}
.tab.active .tab-circle {
  background: var(--theme, rgb(68, 179, 255));
}
.tab-icon {
  width: 44rpx;
  height: 44rpx;
}
.tab-text {
  font-size: 32rpx;
  color: #8C9AA5;
  font-weight: 500;
}
.tab.active .tab-text {
  color: #fff;
}
.tab-label {
  font-size: 24rpx;
  color: #8C9AA5;
}
.tab.active .tab-label {
  color: var(--theme, rgb(68, 179, 255));
}

.tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 80rpx 0;
}

/* 定义说明卡 */
.def-card {
  background: #222530;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 32rpx;
}
.def-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
  margin-bottom: 12rpx;
}
.def-desc {
  font-size: 26rpx;
  color: #b5bbcc;
  line-height: 1.6;
}

/* 时间线 */
.timeline {
  position: relative;
  padding-left: 12rpx;
}
.timeline::before {
  content: '';
  position: absolute;
  left: 130rpx;
  top: 16rpx;
  bottom: 16rpx;
  width: 2rpx;
  background: #2e303d;
}
.timeline-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  position: relative;
}
.timeline-date {
  width: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding-top: 16rpx;
}
.timeline-date .week {
  font-size: 28rpx;
  color: #fff;
}
.timeline-date .day {
  font-size: 22rpx;
  color: #8C9AA5;
  margin-top: 4rpx;
}
.timeline-item::before {
  content: '';
  position: absolute;
  left: 124rpx;
  top: 28rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #fff;
  border: 3rpx solid #2e303d;
}

/* 右侧卡片 */
.timeline-card {
  flex: 1;
  margin-left: 36rpx;
  background: #222530;
  border-radius: 16rpx;
  overflow: hidden;
}
.card-head {
  padding: 14rpx 24rpx;
}
.head-cat {
  font-size: 28rpx;
  font-weight: 500;
  color: #fff;
}
.card-body {
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #d5d5d5;
  line-height: 1.6;
}
