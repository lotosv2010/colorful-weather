/* pages/warning/index.wxss */
page {
  background: #000;
  color: #fff;
}

.warning-page {
  padding: 20rpx 24rpx 40rpx;
}

.tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.alert-card {
  background: rgb(34, 37, 48);
  border-radius: 15px;
  overflow: hidden;
  margin-bottom: 24rpx;
}

/* 头部：icon + headline + 发布时间 */
.alert-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
}
.alert-header-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.alert-header-icon i {
  font-size: 56rpx;
}
.alert-header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.alert-headline {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.5;
  color: #e0e0e0;
}
.alert-time {
  font-size: 22rpx;
  color: #8C9AA5;
  margin-top: 6rpx;
}

/* 内容区块 */
.alert-section {
  padding: 24rpx 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}
.section-title {
  font-size: 26rpx;
  font-weight: 500;
  color: rgb(181, 187, 204);
  margin-bottom: 16rpx;
}
.alert-desc {
  font-size: 26rpx;
  line-height: 1.7;
  color: #b5bbcc;
}
.alert-instruction {
  font-size: 26rpx;
  line-height: 1.7;
  color: #a8d8a8;
}

/* 信息网格 */
.info-grid {
  display: flex;
  flex-wrap: wrap;
}
.info-item {
  width: 50%;
  box-sizing: border-box;
  padding: 10rpx 0;
}
.info-label {
  font-size: 22rpx;
  color: #8C9AA5;
  display: block;
}
.info-value {
  font-size: 26rpx;
  color: #d5d5d5;
  margin-top: 4rpx;
  display: block;
}

/* 数据来源 */
.attributions {
  text-align: center;
  font-size: 20rpx;
  color: #666;
  padding: 20rpx 0 40rpx;
  line-height: 1.5;
}
