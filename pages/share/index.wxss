/* pages/share/index.wxss */
page {
  background: #0f1014;
  color: #fff;
}

.share-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 env(safe-area-inset-bottom, 0);
  box-sizing: border-box;
}

/* ── 可见卡片 ────────────────────────────────── */
.sc-card {
  position: relative;
  width: 375px;
  min-height: 560px;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.6);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 40rpx 32rpx;
  box-sizing: border-box;
}

.sc-logo {
  align-self: flex-start;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
  font-weight: 500;
  letter-spacing: 2rpx;
  margin-bottom: 48rpx;
}

.sc-city {
  font-size: 64rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.1;
  text-align: center;
}

.sc-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 10rpx;
  text-align: center;
}

.sc-icon {
  font-size: 128rpx;
  margin: 40rpx 0 16rpx;
  line-height: 1;
}

.sc-temp {
  font-size: 112rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
  letter-spacing: -4rpx;
}

.sc-weather-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 12rpx;
}

.sc-feels {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
  margin-top: 8rpx;
}

/* ── 信息条 ─────────────────────────────────── */
.sc-info-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  width: 100%;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 20rpx 0;
  margin-top: 40rpx;
}

.sc-info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.sc-info-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.45);
  margin-bottom: 6rpx;
}

.sc-info-val {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.sc-sep {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.15);
}

/* ── 底部水印 ─────────────────────────────────── */
.sc-divider {
  width: 100%;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.12);
  margin-top: 32rpx;
}

.sc-watermark {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.25);
  margin-top: 20rpx;
  letter-spacing: 2rpx;
  text-align: center;
}

/* ── 隐藏 Canvas（仅用于导出，视觉上不显示） ── */
.export-canvas {
  position: absolute;
  left: -9999px;
  top: 0;
  pointer-events: none;
}

/* ── 按钮 ─────────────────────────────────── */
.action-row {
  margin-top: 40rpx;
  width: 100%;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 48rpx;
  background: var(--theme, #1296db);
  transition: opacity 0.15s;
}

.action-btn.btn-loading {
  opacity: 0.6;
  pointer-events: none;
}

.action-btn-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}
