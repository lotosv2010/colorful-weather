<!--pages/weather30/index.wxml-->
<view class="weather30-page">

  <!-- 加载与错误状态 -->
  <view wx:if="{{loading}}" class="tip">加载中...</view>
  <view wx:elif="{{errorMsg}}" class="tip">{{errorMsg}}</view>

  <block wx:else>
    <!-- 头部城市信息 -->
    <page-header district="{{district}}" city="{{city}}" province="{{province}}" />

    <!-- 统计摘要 -->
    <view class="summary-card">
      <text class="summary-text">未来30天{{summary.rainDays ? '将有' + summary.rainDays + '天下雨' : ''}}{{summary.snowDays ? '，' + summary.snowDays + '天下雪' : ''}}，最高温度{{summary.maxTemp}}°（{{summary.maxDate}}），最低温度{{summary.minTemp}}°（{{summary.minDate}}）</text>
    </view>

    <!-- Tabs -->
    <view class="tabs">
      <view class="tab {{activeTab === 'list' ? 'active' : ''}}" bindtap="onTabChange" data-tab="list">
        <text>列表</text>
      </view>
      <view class="tab {{activeTab === 'chart' ? 'active' : ''}}" bindtap="onTabChange" data-tab="chart">
        <text>图表</text>
      </view>
    </view>

    <!-- 列表模式 -->
    <view wx:if="{{activeTab === 'list'}}" class="list-container">
      <scroll-view scroll-y scroll-into-view="{{scrollToDate}}" scroll-with-animation class="list-scroll">
        <view id="card-{{item.fxDate}}" wx:for="{{daily}}" wx:key="fxDate">
          <weather30-card item="{{item}}" active="{{activeDate === item.fxDate}}" />
        </view>
      </scroll-view>
    </view>

    <!-- 图表模式 -->
    <view wx:if="{{activeTab === 'chart'}}" class="chart-container">
      <weather30-chart id="weather30Chart" daily="{{daily}}" bind:select="onChartSelect" />
    </view>
  </block>
</view>
