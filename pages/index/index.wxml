<!--index.wxml-->
<wxs src="/utils/iconColor.wxs" module="ic" />
<wxs src="/utils/tempUnit.wxs" module="tu" />
<view class="page" style="--theme:{{themeColor}}">
  <map
    id="bgMap"
    class="bg-map"
    longitude="{{longitude}}"
    latitude="{{latitude}}"
    scale="9"
    show-location
    enable-3D="{{false}}"
    show-compass="{{false}}"
    enable-scroll="{{mapInteractive}}"
    enable-zoom="{{mapInteractive}}"
    enable-rotate="{{mapInteractive}}"
    markers="{{mapMarkers}}"
    bindtap="onMapTap"
    bindpoitap="onMapPoiTap"
  >
  </map>

  <!-- 地图点击 tips：普通 view 叠在地图上方，跟随点击位置 -->
  <view
    wx:if="{{mapTipsVisible}}"
    class="map-tips"
    style="background: {{weatherBg}}; left: {{mapTipsData.tipX}}px; top: {{mapTipsData.tipY}}px;"
  >
    <view class="map-tips-header">
      <view class="map-tips-location">{{mapTipsData.district}}</view>
      <view class="map-tips-close" catchtap="onMapTipsClose">✕</view>
    </view>
    <view class="map-tips-content" catchtap="onMapTipsTap">
      <view class="map-tips-icon-wrap">
        <text class="map-tips-icon qi-{{mapTipsData.icon || 100}}-fill" style="color: {{mapTipsData.iconColor}};"></text>
      </view>
      <view class="map-tips-body">
        <view class="map-tips-temp">{{tu.fmt(mapTipsData.temp, tempUnit)}}°</view>
        <view class="map-tips-text-row">
          <text class="map-tips-text">{{mapTipsData.text}}</text>
          <text class="map-tips-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 天气粒子动效层 -->
  <weather-particles
    wx:if="{{weatherEffect.particle}}"
    weatherEffect="{{weatherEffect.particle}}"
    sheetProgress="{{sheetProgress}}"
  />

  <!-- 离线模式横幅 -->
  <view wx:if="{{offline}}" class="offline-banner">
    <text class="offline-dot"></text>
    <text class="offline-text">离线模式 · 展示缓存数据</text>
  </view>

  <!-- 地图定位按钮：跟随地图显示/隐藏，sheet 展开时淡出 -->
  <view
    class="locate-btn {{sheetExpanded ? '' : 'locate-interactive'}}"
    style="opacity: {{1 - sheetProgress}};"
    catchtap="onLocateTap"
  >
    <weather-icon class="locate-icon" src="/static/icons/locate.svg" colors="{{['#333']}}" />
  </view>

  <!-- 顶部搜索栏：随 progress 渐入；容器不拦截手势，仅子元素响应点击 -->
  <view class="top-bar" style="opacity: {{sheetProgress}};">
    <view class="top-search {{sheetExpanded ? 'top-interactive' : ''}}" bindtap="showSelector">
      <icon class="top-search-icon" type="search" color="#fff" size="24"></icon>
      <view class="top-search-text">{{ locationLabel || '搜索城市' }}</view>
    </view>
    <view class="top-locate {{sheetExpanded ? 'top-interactive' : ''}}" catchtap="onLocateTap">
      <weather-icon class="top-locate-icon" src="/static/icons/locate.svg" colors="{{['#fff']}}" />
    </view>
  </view>

  <bottom-sheet id="sheet" weatherBg="{{weatherBg}}" bind:change="onSheetChange" bind:progress="onSheetProgress" bind:dragstart="onSheetDragStart" bind:dragend="onSheetDragEnd">
    <!-- 紧凑卡片上方外侧胶囊 -->
    <view slot="compact-above" class="compact-above-row" style="opacity: {{1 - sheetProgress}};">
      <view wx:if="{{air.aqi}}" class="capsule aqi-capsule" catchtap="onAirTap">
        <view class="aqi-leaf">
          <weather-icon class="aqi-leaf-icon" src="/static/icons/leaf.svg" colors="{{['#fff']}}" />
        </view>
        <text class="capsule-label">AQI</text>
        <text class="capsule-value">{{air.aqi}}</text>
        <text class="capsule-desc">{{air.category}}</text>
      </view>
      <view wx:else></view>
      <view class="capsule-right">
        <view wx:if="{{alerts.length}}" class="capsule warning-capsule" catchtap="gotoWarning">
          <i class="capsule-icon qi-9999"></i>
          <text class="capsule-text">{{alerts.length > 1 ? '多种天气预警正在发生' : alerts[0].headline}}</text>
          <text class="capsule-arrow">›</text>
        </view>
        <view wx:if="{{showMinutelyEntry}}" class="capsule minutely-capsule" catchtap="onMinutelyTap">
          <i class="capsule-icon qi-{{minutelyType === 'snow' ? 499 : 399}}-fill"></i>
          <text class="capsule-text">{{minutelySummary || '分钟级雨量'}}</text>
          <text class="capsule-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 紧凑卡片 -->
    <view slot="compact" style="opacity: {{1 - sheetProgress}};">
      <view class="decor-wrapper">
        <weather-decor wx:if="{{weatherEffect.decor}}" weatherEffect="{{weatherEffect.decor}}" mode="compact" />
        <compact-weather
          weather="{{currentWeather}}"
          locationLabel="{{locationLabel}}"
          dateNow="{{dateNow}}"
          desc="{{desc}}"
          tempUnit="{{tempUnit}}"
          loading="{{loading}}"
          errorMsg="{{errorMsg}}"
          weatherBg="{{weatherBg}}"
          bind:getnow="getWeather"
          bind:retry="onRetry"
          bind:showselector="showSelector"
          bind:refresh="onRefresh"
        />
      </view>
    </view>

    <!-- 全部卡片列表 -->
    <view slot="full" class="full-list">
      <block wx:if="{{!loading && !errorMsg}}">
      <view class="decor-wrapper">
        <weather-decor wx:if="{{weatherEffect.decor}}" weatherEffect="{{weatherEffect.decor}}" mode="full" />
        <weather-temp
        weather="{{currentWeather}}"
        city="{{district}}"
        date="{{dateNow}}"
        desc="{{desc}}"
        uv="{{uv}}"
        alerts="{{alerts}}"
        tempUnit="{{tempUnit}}"
        showMinutelyEntry="{{showMinutelyEntry}}"
        minutelyType="{{minutelyType}}"
        minutelySummary="{{minutelySummary}}"
        weatherBg="{{weatherBg}}"
        bind:getnow="getWeather"
        bind:gowarning="gotoWarning"
        bind:minutelytap="onMinutelyTap"
        class="weather-temp"
      />
      </view>
      <weather-hourly hourly="{{hourly}}" tempUnit="{{tempUnit}}" bind:itemtap="onHourlyTap" />
      <weather-daily
        daily="{{daily}}"
        tempUnit="{{tempUnit}}"
        location="{{longitude}},{{latitude}}"
        province="{{province}}"
        city="{{city}}"
        district="{{district}}"
      />
      <weather-air
        air="{{air}}"
        location="{{longitude}},{{latitude}}"
        province="{{province}}"
        city="{{city}}"
        district="{{district}}"
      />
      <weather-astronomy sun="{{astronomySun}}" moon="{{astronomyMoon}}" />
      <weather-life
        indices="{{indices}}"
        location="{{longitude}},{{latitude}}"
        province="{{province}}"
        city="{{city}}"
        district="{{district}}"
      />
      <weather-timemachine
        cityId="{{cityId}}"
        tempUnit="{{tempUnit}}"
        themeColor="{{themeColor}}"
      />
      </block>
      <block wx:elif="{{errorMsg}}">
        <error-state errorMsg="{{errorMsg}}" bind:retry="onRetry" />
      </block>
      <block wx:else>
        <view class="sk-full-list">
          <!-- weather-temp 骨架 -->
          <view class="sk-card sk-card-temp">
            <view class="sk-row">
              <view class="sk-bar sk-bar-lg"></view>
              <view class="sk-bar sk-bar-md" style="margin-left: auto;"></view>
            </view>
            <view class="sk-row" style="margin-top: 16rpx;">
              <view class="sk-bar sk-bar-sm"></view>
            </view>
          </view>
          <!-- hourly 骨架 -->
          <view class="sk-card">
            <view class="sk-bar sk-bar-sm" style="margin-bottom: 16rpx;"></view>
            <view class="sk-scroll-row">
              <view class="sk-scroll-item" wx:for="{{6}}" wx:key="*this">
                <view class="sk-bar sk-bar-xs"></view>
                <view class="sk-circle-sm"></view>
                <view class="sk-bar sk-bar-xs"></view>
              </view>
            </view>
          </view>
          <!-- daily 骨架 -->
          <view class="sk-card">
            <view class="sk-bar sk-bar-sm" style="margin-bottom: 16rpx;"></view>
            <view class="sk-row" wx:for="{{4}}" wx:key="*this" style="margin-top: {{index > 0 ? '16rpx' : '0'}};">
              <view class="sk-bar sk-bar-xs"></view>
              <view class="sk-bar sk-bar-xs" style="margin: 0 16rpx;"></view>
              <view class="sk-bar sk-bar-fill" style="flex: 1;"></view>
              <view class="sk-bar sk-bar-xs" style="margin-left: 16rpx;"></view>
            </view>
          </view>
          <!-- air 骨架 -->
          <view class="sk-card">
            <view class="sk-row">
              <view class="sk-circle-lg"></view>
              <view style="flex: 1; margin-left: 24rpx;">
                <view class="sk-bar sk-bar-md"></view>
                <view class="sk-bar sk-bar-sm" style="margin-top: 12rpx;"></view>
              </view>
            </view>
          </view>
          <!-- astronomy 骨架 -->
          <view class="sk-card">
            <view class="sk-bar sk-bar-sm"></view>
            <view class="sk-bar sk-bar-fill" style="margin-top: 16rpx; height: 120rpx;"></view>
          </view>
          <!-- life 骨架 -->
          <view class="sk-card">
            <view class="sk-grid-4">
              <view class="sk-grid-item" wx:for="{{4}}" wx:key="*this">
                <view class="sk-circle-sm"></view>
                <view class="sk-bar sk-bar-xs" style="margin-top: 12rpx;"></view>
              </view>
            </view>
          </view>
          <!-- timemachine 骨架 -->
          <view class="sk-card">
            <view class="sk-bar sk-bar-md"></view>
            <view class="sk-bar sk-bar-fill" style="margin-top: 16rpx; height: 200rpx;"></view>
          </view>
        </view>
      </block>
    </view>
  </bottom-sheet>

  <city-search show="{{selectorVisible}}" tempUnit="{{tempUnit}}" current="{{ {name: district, adm1: province, adm2: city, lat: latitude, lon: longitude} }}" bind:select="onSelectCity" bind:close="hideSelector" />
</view>
