<!--index.wxml-->
<view class="weather">
  <view class="header">
    <view class="weather-search" bindtap="showSelector">
      <icon class="icon-small" type="search" color="#fff" size="24"></icon>
      <view class="icon-title">搜索</view>
    </view>
    <view class="weather-location" bindtap="init">
      <view class="icon-title">当前位置</view>
    </view>
  </view>
  <view class="container">
    <view class="minutely-entry" bindtap="onMinutelyTap">
      <i class="qi-{{minutelyType === 'snow' ? 499 : 399}}-fill minutely-entry-icon"></i>
      <i class="qi-1803 typhoon-entry-icon" catchtap="onTyphoonTap"></i>
    </view>
    <weather-temp
      weather="{{currentWeather}}"
      city="{{currentCity}}"
      date="{{dateNow}}"
      desc="{{desc}}"
      uv="{{uv}}"
      alerts="{{alerts}}"
      bind:getnow="getWeather"
      bind:gowarning="gotoWarning"
      class="weather-temp"
    />
    <weather-hourly
      hourly="{{hourly}}"
      bind:itemtap="onHourlyTap"
    />
    <weather-daily
      daily="{{daily}}"
      location="{{longitude}},{{latitude}}"
      province="{{province}}"
      district="{{district}}"
    />
    <weather-air
      air="{{air}}"
      location="{{longitude}},{{latitude}}"
      province="{{province}}"
      district="{{district}}"
    />
    <weather-astronomy
      sun="{{astronomySun}}"
      moon="{{astronomyMoon}}"
    />
    <weather-life
      indices="{{indices}}"
      location="{{longitude}},{{latitude}}"
      province="{{province}}"
      district="{{district}}"
    />
  </view>
  <city-search show="{{selectorVisible}}" bind:select="onSelectCity" bind:close="hideSelector" />
</view>
