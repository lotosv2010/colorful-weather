/**index.wxss**/
page {
  background-color: #000;
  height: 100%;
  overflow: hidden;
}

.page {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  background-color: #000;
}

.bg-map {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* 地图点击 tips */
.map-tips {
  position: absolute;
  z-index: 50;
  padding: 20rpx 20rpx 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.35);
  max-width: 480rpx;
  min-width: 280rpx;
  text-align: center;
}

.map-tips-header {
  position: relative;
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.map-tips-location {
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.9);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.map-tips-close {
  position: absolute;
  right: -8rpx;
  top: -8rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.55);
}

.map-tips-content {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
}

.map-tips-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.map-tips-icon {
  font-size: 56rpx;
  line-height: 1;
  color: #fff;
}

.map-tips-body {
  min-width: 0;
  text-align: center;
}

.map-tips-temp {
  font-size: 44rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1;
  margin-bottom: 8rpx;
  text-align: left;
}

.map-tips-text-row {
  display: flex;
  align-items: center;
}

.map-tips-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.map-tips-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-left: 10rpx;
  line-height: 1;
}

/* 离线模式横幅：顶部安全区下方，居中胶囊 */
.offline-banner {
  position: fixed;
  top: 100rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 40;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 24rpx;
  border-radius: 28rpx;
  background-color: rgba(212, 56, 13, 0.92);
  color: #fff;
  font-size: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.4);
  pointer-events: none;
}

.offline-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #fff;
  opacity: 0.85;
}

.offline-text {
  line-height: 1;
}

/* 地图定位按钮：右上角，尺寸与 top-bar 定位按钮保持一致 */
.locate-btn {
  position: fixed;
  top: 24rpx;
  right: 32rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.92);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 20;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.locate-btn.locate-interactive {
  pointer-events: auto;
}

.locate-icon {
  width: 32rpx;
  height: 32rpx;
}

/* 顶部搜索栏：容器永远不拦截手势，避免遮挡 sheet 下拉手柄；子元素按需开启交互 */
.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  color: #fff;
  pointer-events: none;
}

.top-bar .top-interactive {
  pointer-events: auto;
}

.top-search {
  display: flex;
  align-items: center;
  height: 56rpx;
  flex: 1;
  color: #fff;
  min-width: 0;
}

.top-search-icon {
  margin-right: 10rpx;
}

.top-search-text {
  font-size: 32rpx;
  line-height: 32rpx;
  font-weight: 400;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* top-bar 右侧定位按钮 */
.top-locate {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: var(--theme, rgba(255, 255, 255, 0.15));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.top-locate-icon {
  width: 32rpx;
  height: 32rpx;
}

/* 紧凑卡片外侧胶囊行 */
.compact-above-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0;
  box-sizing: border-box;
  width: 100%;
  transition: opacity 0.3s ease;
  gap: 16rpx;
}

.capsule {
  display: flex;
  align-items: center;
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 28rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 24rpx;
  line-height: 1;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.25);
  max-width: 100%;
  box-sizing: border-box;
}

.capsule-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.capsule-label {
  font-weight: 500;
  margin-right: 6rpx;
}

.capsule-value {
  font-weight: 600;
  margin-right: 8rpx;
}

.capsule-desc {
  opacity: 0.95;
}

.capsule-text {
  flex: 1;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.capsule-arrow {
  margin-left: 8rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  flex-shrink: 0;
}

.capsule-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  max-width: 66%;
  min-width: 0;
}

.capsule-right .capsule {
  width: 100%;
}

.warning-capsule .capsule-icon {
  color: #ffb366;
}

.minutely-capsule .capsule-icon {
  color: #5BA3D9;
}

.aqi-capsule {
  background-color: rgba(0, 0, 0, 0.5);
  padding-left: 8rpx;
}

.aqi-leaf {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #7FC359;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.aqi-leaf-icon {
  width: 24rpx;
  height: 24rpx;
}

/* 紧凑卡片样式已迁移到 components/compact-weather/index.wxss */

/* 天气装饰层包裹器 */
.decor-wrapper {
  position: relative;
  overflow: hidden;
}

/* 紧凑卡中部 / 描述：复用 weather-header 系列样式 */
.weather-header-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: rgb(181, 187, 204);
}
.weather-header-main {
  height: 4.5rem;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 16px;
}
.weather-header-svg {
  font-size: 4.5rem;
}
.weather-header-left {
  height: 100%;
  font-size: 2rem;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  margin-left: 10px;
  color: #fff;
}
.weather-header-temp {
  height: 2rem;
  line-height: 2rem;
  position: relative;
}
.weather-header-unit {
  font-size: 1rem;
  height: 1rem;
  line-height: 1rem;
  position: absolute;
  top: 0px;
  right: -12px;
  margin-left: 5px;
}
.weather-header-text {
  font-size: 1.2rem;
}
.weather-header-desc {
  font-size: 0.8rem;
  text-align: center;
  margin-top: 15px;
  font-weight: 300;
  color: #A6A9AD;
}

/* 全部列表里 weather-temp 间距 */
.full-list .weather-temp {
  display: block;
  margin-bottom: 16rpx;
}

/* ========== 骨架屏样式 ========== */

@keyframes sk-shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.sk-bar {
  background: linear-gradient(90deg,
    rgba(255,255,255,0.04) 0%,
    rgba(255,255,255,0.10) 50%,
    rgba(255,255,255,0.04) 100%
  );
  background-size: 200% 100%;
  border-radius: 4px;
  animation: sk-shimmer 1.4s ease-in-out infinite;
}

.sk-bar-lg { width: 80%; height: 22px; }
.sk-bar-md { width: 60%; height: 14px; }
.sk-bar-sm { width: 40%; height: 12px; }
.sk-bar-xs { width: 30%; height: 10px; }
.sk-bar-fill { width: 100%; }

.sk-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(90deg,
    rgba(255,255,255,0.04) 0%,
    rgba(255,255,255,0.10) 50%,
    rgba(255,255,255,0.04) 100%
  );
  background-size: 200% 100%;
  animation: sk-shimmer 1.4s ease-in-out infinite;
  flex-shrink: 0;
}

.sk-circle-sm {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(90deg,
    rgba(255,255,255,0.04) 0%,
    rgba(255,255,255,0.10) 50%,
    rgba(255,255,255,0.04) 100%
  );
  background-size: 200% 100%;
  animation: sk-shimmer 1.4s ease-in-out infinite;
  flex-shrink: 0;
}

.sk-circle-lg {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(90deg,
    rgba(255,255,255,0.04) 0%,
    rgba(255,255,255,0.10) 50%,
    rgba(255,255,255,0.04) 100%
  );
  background-size: 200% 100%;
  animation: sk-shimmer 1.4s ease-in-out infinite;
  flex-shrink: 0;
}

/* compact 卡片骨架屏样式已迁移到 components/compact-weather/index.wxss */

/* full-list 骨架屏 */
.sk-full-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sk-card {
  background: rgba(34, 37, 48, 0.95);
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.sk-card-temp {
  padding: 32rpx 24rpx;
}

.sk-row {
  display: flex;
  align-items: center;
}

.sk-scroll-row {
  display: flex;
  gap: 24rpx;
  overflow: hidden;
}

.sk-scroll-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  width: 80rpx;
}

.sk-grid-4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.sk-grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 城市切换圆点指示器 */
.city-dots {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10rpx;
  padding: 6rpx 0 2rpx;
}

.city-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.35);
  transition: all 0.25s;
}

.city-dot-active {
  width: 22rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, 0.9);
}

